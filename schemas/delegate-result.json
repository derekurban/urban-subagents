{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DelegateResult",
  "type": "object",
  "required": [
    "session_id",
    "status",
    "result",
    "provider_handle",
    "duration_ms",
    "runtime"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["running", "idle", "completed", "failed", "interrupted"]
    },
    "result": {
      "type": "string"
    },
    "provider_handle": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "runtime": {
      "type": "string",
      "enum": ["claude_code", "codex_exec"]
    }
  },
  "additionalProperties": false
}
